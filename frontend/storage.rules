rules_version = '2';

// Firebase Storage Rules
service firebase.storage {
  match /b/{bucket}/o {

    // 1. SECURE BACKUPS: Only Firebase Admins (via Admin SDK) can access this.
    // The web/mobile client is completely blocked.
    match /backups/{allPaths=**} {
      allow read, write: if false;
    }

    // 2. PUBLIC/APP ASSETS: Allow logged-in users to read analytics or other data
    match /{allPaths=**} {
      // Allow read for authenticated users for everything ELSE
      allow read: if request.auth != null;

      // Always block client-side writes
      allow write: if false;
    }
  }
}