rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole(appId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/artifacts/$(appId)/public/data/userRoles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/artifacts/$(appId)/public/data/userRoles/$(request.auth.uid)).data.role
        : null;
    }

    function isSuperAdmin(appId) {
      return getUserRole(appId) == 'superadmin';
    }

    function isAdmin(appId) {
      return getUserRole(appId) in ['admin', 'superadmin'];
    }

    function isOfficialCreator(appId) {
      return getUserRole(appId) in ['superadmin', 'admin', 'tournament_creator'];
    }

    match /artifacts/{appId}/public/data {

      // 1. PLAYERS
      match /players/{playerId} {
        allow read, list, create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if isSuperAdmin(appId);
      }

      // 2. SEASONS
      match /seasons/{seasonId} {
        allow read, list: if request.auth != null;
        allow write: if isSuperAdmin(appId) || request.auth != null;
      }

      // 3. TOURNAMENTS
      match /tournaments/{tournamentId} {
        allow read, list: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null;
      }

      // 4. SECRETS
      match /secrets/{tournamentId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null;
      }

      // 5. ADMINS
      match /admins/{adminDoc} {
        allow read, create, update, delete: if request.auth != null;
      }

      // 6. GLOBAL SETTINGS
      match /settings/{docId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      // 8. USAGE (analytics tracking)
      match /usage/{userId} {
        allow read: if isSuperAdmin(appId) || (request.auth != null && userId == 'analyticsMetadata');
        allow create, update: if request.auth != null && request.auth.uid == userId;
      }

      // 9. USER ROLES
      match /userRoles/{uid} {
        allow read, list, create: if request.auth != null;
        allow update: if isSuperAdmin(appId);
        allow delete: if isSuperAdmin(appId);
      }
    }
  }
}
