# Set these in your Vercel project settings (Environment Variables)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Your Firebase Hosting URL (or localhost for dev)
FRONTEND_URL=https://raggooner-uma-2026.web.app

# Firebase Admin SDK service account JSON (base64 encoded)
# Generate from: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
APP_ID=raggooner-uma-2026
